# Agency HQ — Environment Configuration
# Copy this to .env.local and adjust as needed.

# Mode: 'live' = reads real OpenClaw sessions, 'demo' = simulated data
# On Vercel, defaults to 'demo' automatically.
ARENA_MODE=demo

# OpenClaw home directory (optional — defaults to ~/.openclaw)
# OPENCLAW_HOME=/home/youruser/.openclaw
